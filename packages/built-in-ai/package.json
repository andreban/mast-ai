    "test": "vitest"
  },
  "dependencies": {
    "@mast-ai/core": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}
